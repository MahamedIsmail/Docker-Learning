Redis_host=redis_db
Redis_port=default Redis port is 6379, but you can change it if your Redis server is configured to use a different port.
MESSAGE=An example message to be displayed in the Flask app
APP_PORT=Port number to run the Flask app
Binding_IP=Choice of IP address to bind the Flask app
Maps_API_KEY=DemoAPIKEY #Demo API Key, note for production use, please get your own API key from Google Cloud Console and replace the value of Mapas_API_KEY in this .env file.